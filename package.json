{
  "name": "wcrs",
  "version": "1.0.0",
  "description": "Workflow Capture + Replay System - Enterprise browser workflow observability and compilation tool",
  "author": "Metaphy LLC (Logan)",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "build:extension": "cp -r extension dist/extension",
    "cli": "node dist/cli.js",
    "map": "node dist/cli.js map",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "xstate": "^5.18.0",
    "js-yaml": "^4.1.0",
    "pdf-parse": "^1.1.1",
    "pixelmatch": "^5.3.0",
    "pngjs": "^7.0.0",
    "graphlib": "^2.1.8",
    "commander": "^12.0.0",
    "uuid": "^9.0.0",
    "ajv": "^8.12.0",
    "fast-diff": "^1.3.0",
    "glob": "^10.3.10"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/uuid": "^9.0.0",
    "@types/pngjs": "^6.0.4",
    "@types/pixelmatch": "^5.2.6",
    "@types/graphlib": "^2.1.8",
    "@types/pdf-parse": "^1.1.4",
    "@types/jest": "^29.5.12",
    "typescript": "^5.4.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts"
    ],
    "moduleNameMapper": {
      "^(.*)\\.js$": "$1"
    }
  }
}
